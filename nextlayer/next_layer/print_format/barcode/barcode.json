 "html": "<style>\n    .print-format {\n        width: 8cm;\n        height: 10cm;\n        padding: 5px;\n    }\n    \n    @page {\n        size: 8cm 10cm;\n        margin: 0;\n    }\n\n    body {\n        font-family: Arial, sans-serif;\n        font-size: 10px;\n    }\n\n    .container {\n        width: 100%;\n        text-align: center;\n        padding: 5px;\n    }\n\n    .title {\n        font-size: 10px;\n        font-weight: bold;\n        margin-bottom: 5px;\n    }\n\n    .barcode img {\n        width: 100%;\n        margin-top: 5px;\n    }\n</style>\n\n<div class=\"container\">\n    <div class=\"title\">{{ doc.item_name }}</div>\n\n    {% set barcode = frappe.db.get_all(\n        \"Item Barcode\",\n        filters={\"parent\": doc.name},\n        fields=[\"custom_image\"],\n        limit=1\n    ) %}\n\n    {% if barcode and barcode[0].custom_image %}\n        <div class=\"barcode\">\n            <img src=\"{{ barcode[0].custom_image }}\">\n        </div>\n    {% else %}\n        <div class=\"barcode\">\n            <p>No barcode available</p>\n        </div>\n    {% endif %}\n</div>\n",
