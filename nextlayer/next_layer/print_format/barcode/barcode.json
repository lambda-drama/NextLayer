 "html": "<style>\n    .print-format {\n        width: 8cm;\n        height: 10cm;\n        padding: 5px;\n        border: 1px solid black; /* \u2705 visible boundary for label edge */\n        box-sizing: border-box;\n    }\n    \n    @page {\n        size: 8cm 10cm;\n        margin: 0;\n    }\n\n    body {\n        font-family: Arial, sans-serif;\n        font-size: 10px;\n    }\n\n    .container {\n        width: 100%;\n        text-align: center;\n        padding: 5px;\n        box-sizing: border-box;\n    }\n\n    .title {\n        font-size: 10px;\n        font-weight: bold;\n        margin-bottom: 5px;\n        text-transform: uppercase;\n    }\n\n    .info {\n        text-align: left;\n        margin: 5px 0;\n        line-height: 1.2;\n        font-size: 10px;\n    }\n\n    .barcode img {\n        width: 100%;\n        max-height: 4cm;\n        object-fit: contain;\n        margin-top: 5px;\n    }\n\n    .footer {\n        text-align: center;\n        margin-top: 5px;\n        font-weight: bold;\n        font-size: 10px;\n        text-transform: uppercase;\n    }\n</style>\n\n<div class=\"print-format\">\n    <div class=\"container\">\n        <div class=\"title\">{{ doc.item_name }}</div>\n        <div class=\"info\">\n            <div><strong>Marka:</strong> MRK - R&gt;M&gt;D</div>\n            <div><strong>Machine No.:</strong> ART-RYL-AIR</div>\n            <div><strong>Item Code:</strong> {{ doc.item_code }}</div>\n        </div>\n\n        {% set barcode = frappe.db.get_all(\n            \"Item Barcode\",\n            filters={\"parent\": doc.name},\n            fields=[\"custom_image\"],\n            limit=1\n        ) %}\n\n        {% if barcode and barcode[0].custom_image %}\n            <div class=\"barcode\">\n                <img src=\"{{ barcode[0].custom_image }}\">\n            </div>\n        {% else %}\n            <div class=\"barcode\">\n                <p>No barcode available</p>\n            </div>\n        {% endif %}\n\n        <div class=\"footer\">Made in India</div>\n    </div>\n</div>\n",
